<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Outreach Generator</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap');

  :root {
    --bg: #0a0a0a;
    --surface: #111111;
    --border: #1f1f1f;
    --accent: #c8f135;
    --accent-dim: rgba(200, 241, 53, 0.08);
    --text: #e8e8e8;
    --muted: #555;
    --error: #ff4d4d;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    padding: 40px 20px;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
  }

  header {
    margin-bottom: 48px;
  }

  .label-tag {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
    display: block;
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 8vw, 88px);
    line-height: 0.9;
    letter-spacing: 1px;
    color: #fff;
  }

  h1 span {
    color: var(--accent);
  }

  .subtitle {
    margin-top: 16px;
    color: var(--muted);
    font-size: 14px;
    font-family: 'DM Mono', monospace;
  }

  .form-grid {
    display: grid;
    gap: 0;
  }

  .section {
    border: 1px solid var(--border);
    border-bottom: none;
    padding: 28px 32px;
    background: var(--surface);
    transition: background 0.2s;
  }

  .section:first-of-type { border-radius: 8px 8px 0 0; }
  .section:last-of-type { border-bottom: 1px solid var(--border); border-radius: 0 0 8px 8px; }

  .section-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .field {
    margin-bottom: 20px;
  }

  .field:last-child { margin-bottom: 0; }

  label {
    display: block;
    font-size: 12px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    margin-bottom: 8px;
    letter-spacing: 0.5px;
  }

  input, textarea, select {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    padding: 12px 16px;
    border-radius: 6px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
  }

  input:focus, textarea:focus, select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(200, 241, 53, 0.07);
  }

  textarea { min-height: 90px; }

  .bottleneck-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .bottleneck-item {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px;
    position: relative;
  }

  .bottleneck-item .badge {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 3px;
    margin-bottom: 12px;
    display: inline-block;
  }

  .badge.primary { background: rgba(200,241,53,0.15); color: var(--accent); }
  .badge.secondary { background: rgba(255,255,255,0.06); color: #888; }
  .badge.additional { background: rgba(255,255,255,0.03); color: #555; }

  .bottleneck-item label { margin-top: 10px; }
  .bottleneck-item input, .bottleneck-item textarea { background: var(--surface); }

  .generate-btn {
    width: 100%;
    margin-top: 20px;
    padding: 18px;
    background: var(--accent);
    color: #000;
    border: none;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    cursor: pointer;
    border-radius: 8px;
    transition: opacity 0.2s, transform 0.1s;
  }

  .generate-btn:hover { opacity: 0.9; }
  .generate-btn:active { transform: scale(0.99); }
  .generate-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .output-section {
    margin-top: 32px;
    display: none;
  }

  .output-section.visible { display: block; }

  .output-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .output-header {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .output-title {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
  }

  .copy-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    padding: 6px 14px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .copy-btn:hover { border-color: var(--accent); color: var(--accent); }
  .copy-btn.copied { border-color: var(--accent); color: var(--accent); }

  .output-body {
    padding: 24px;
    font-size: 14px;
    line-height: 1.8;
    color: #ccc;
    white-space: pre-wrap;
    font-family: 'DM Sans', sans-serif;
  }

  .loading {
    text-align: center;
    padding: 40px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 2px;
    display: none;
  }

  .loading.visible { display: block; }

  .dot-anim::after {
    content: '';
    animation: dots 1.5s infinite;
  }

  @keyframes dots {
    0% { content: ''; }
    33% { content: '.'; }
    66% { content: '..'; }
    100% { content: '...'; }
  }

  .error-msg {
    background: rgba(255,77,77,0.08);
    border: 1px solid rgba(255,77,77,0.2);
    color: var(--error);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    padding: 14px 18px;
    border-radius: 6px;
    margin-top: 16px;
    display: none;
  }

  .error-msg.visible { display: block; }

  @media (max-width: 600px) {
    .bottleneck-group { grid-template-columns: 1fr; }
    .section { padding: 20px; }
  }
</style>
</head>
<body>
<div class="container">
  <header>
    <span class="label-tag">// outreach system</span>
    <h1>DM + LOOM<br><span>GENERATOR</span></h1>
    <p class="subtitle">fill in the prospect details → get your scripts</p>
  </header>

  <div class="form-grid">
    <!-- Prospect Info -->
    <div class="section">
      <div class="section-title">Prospect Info</div>
      <div class="field">
        <label>Prospect Name</label>
        <input type="text" id="name" placeholder="e.g. Dukes" />
      </div>
      <div class="field">
        <label>Niche</label>
        <input type="text" id="niche" placeholder="e.g. Trading, Fitness, Real Estate" />
      </div>
      <div class="field">
        <label>Their Offer (what they sell)</label>
        <input type="text" id="offer" placeholder="e.g. Helping traders become profitable" />
      </div>
    </div>

    <!-- Bottlenecks -->
    <div class="section">
      <div class="section-title">Bottlenecks + Problems</div>
      <p style="font-size:12px;color:var(--muted);margin-bottom:20px;font-family:'DM Mono',monospace;">Enter all bottlenecks you spotted — the AI will prioritize them automatically.</p>

      <div class="bottleneck-group">
        <div class="bottleneck-item">
          <span class="badge primary">Primary</span>
          <div class="field">
            <label>Bottleneck</label>
            <input type="text" id="b1" placeholder="e.g. No credibility in bio" />
          </div>
          <div class="field">
            <label>Experienced Problem</label>
            <textarea id="p1" placeholder="e.g. People don't trust them before seeing the offer"></textarea>
          </div>
        </div>

        <div class="bottleneck-item">
          <span class="badge secondary">Secondary</span>
          <div class="field">
            <label>Bottleneck</label>
            <input type="text" id="b2" placeholder="e.g. Weak landing page" />
          </div>
          <div class="field">
            <label>Experienced Problem</label>
            <textarea id="p2" placeholder="e.g. Attracting unqualified leads"></textarea>
          </div>
        </div>

        <div class="bottleneck-item" style="grid-column: 1 / -1;">
          <span class="badge additional">Additional</span>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="field">
              <label>Bottleneck</label>
              <input type="text" id="b3" placeholder="e.g. Free community + 3 packages" />
            </div>
            <div class="field">
              <label>Experienced Problem</label>
              <textarea id="p3" placeholder="e.g. Attracting brokies, can't scale"></textarea>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Webinar Link -->
    <div class="section">
      <div class="section-title">Webinar Link</div>
      <div class="field">
        <label>Webinar Link Placeholder (optional)</label>
        <input type="text" id="webinarLink" placeholder="{custom webinar link}" />
      </div>
    </div>
  </div>

  <button class="generate-btn" onclick="generate()">GENERATE SCRIPTS</button>
  <div class="error-msg" id="errorMsg"></div>

  <div class="loading" id="loading">
    <span class="dot-anim">GENERATING YOUR SCRIPTS</span>
  </div>

  <div class="output-section" id="outputSection">
    <div class="output-card">
      <div class="output-header">
        <span class="output-title">Initial DM</span>
        <button class="copy-btn" onclick="copyText('dmOutput', this)">COPY</button>
      </div>
      <div class="output-body" id="dmOutput"></div>
    </div>

    <div class="output-card">
      <div class="output-header">
        <span class="output-title">Loom Script</span>
        <button class="copy-btn" onclick="copyText('loomOutput', this)">COPY</button>
      </div>
      <div class="output-body" id="loomOutput"></div>
    </div>
  </div>
</div>

<script>
async function generate() {
  const name = document.getElementById('name').value.trim();
  const niche = document.getElementById('niche').value.trim();
  const offer = document.getElementById('offer').value.trim();
  const b1 = document.getElementById('b1').value.trim();
  const p1 = document.getElementById('p1').value.trim();
  const b2 = document.getElementById('b2').value.trim();
  const p2 = document.getElementById('p2').value.trim();
  const b3 = document.getElementById('b3').value.trim();
  const p3 = document.getElementById('p3').value.trim();
  const webinarLink = document.getElementById('webinarLink').value.trim() || '{custom webinar link}';

  const WEBINAR_BENEFITS = `
REVENUE & PROFITABILITY:
- One 2-hour webinar = 10-20 sales vs 20+ hours of individual calls (10-15x more efficient). Example: $39K/hour vs $2,600/hour with 1:1 calls.
- Explosive revenue spikes: $120K in 3 days (organic, <5K followers), $130K in one week, $240K in two weeks, $50K+ per webinar once optimized.
- Multiple revenue waves from a single webinar: 40-50% live, 20-30% next 48hrs (replay + urgency), 10-15% days 3-7, 10-15% weeks 2-4 (WhatsApp reruns), 5-10% ongoing evergreen. One webinar generates income for 4-6 weeks.
- Consistent 5-10x ROAS on paid ads. First webinar: 3-5x typical. Optimized: 5-10x+. Some campaigns hit 10-17x on first webinar. Already profitable at $20 CPL targeting upmarket.
- Front-end order bumps ($27-97) offset ad costs entirely. Can make campaigns profitable on front-end alone.
- Predictable mathematical revenue: $X ad spend = Y registrants = Z revenue. Direct correlation. Can forecast monthly revenue and scale proportionally.

CONVERSION & CLOSE RATES:
- 60-70% close rates on sales calls vs 20-30% traditional. Leads are pre-sold before the call. Calls become cash collection, not convincing. Higher show rates (75%+).
- 10-20% of attendees book calls. 200 attendees = 20-40 booked calls = 8-16 clients at 40% close. Even higher on warm/organic traffic.
- Converts leads who won't book regular calls — opens up 40-60% of audience that avoids sales calls. "Free training" feels safer than "sales call."
- Higher AOV. Webinar leads close at higher ticket prices. Bigger packages and upsells land better.

TRUST & POSITIONING:
- Builds massive trust in 90 minutes. Traditional methods need 7+ hours of content consumption. Webinars achieve the same in 1.5-2 hours live. Average watch time: 1hr 50min. 3-5x faster trust-building.
- Demonstrates real expertise live. Anyone can read a VSL script. Only real experts can teach live for 90 minutes. Q&A proves expertise in real-time. Eliminates guru skepticism instantly.
- Live = proof of authenticity. Unscripted moments show real personality. Can't fake live expertise. Genuine human connection. More credible than polished scripted content.
- Premium positioning and authority. Hosting webinars = industry leader status. You're the expert teaching, not selling. Elevates you above competitors.
- Eliminates market skepticism. Info space is saturated with scammers. Live demonstration proves you're legit. Separates you from course creators.

EFFICIENCY & LEVERAGE:
- One-to-many selling at scale. Explain offer once to 200 people vs 200 times individually. Handle objections once, everyone benefits. Infinitely scalable.
- No time-for-money trade. Same 2 hours whether 50 or 500 attend. Revenue per hour increases with scale. True leverage model.
- Handles objections at scale. One person asks = 10+ people get the answer. Address top 10 objections in presentation. Live Q&A eliminates remaining concerns.
- Sales team efficiency. Closers only talk to pre-sold leads. Shorter calls (15-30min vs 60min). Higher close rates = less calls needed.
- Works without big audience. Paid ads generate registrants from zero. 300-500 registrants possible with $2-3K ad spend.

REPLICABILITY & AUTOMATION:
- Build once, run weekly/monthly forever. Same presentation, new audiences. Predictable results every time. Turn on/off at will with ad spend.
- Evergreen sales asset. Record once, use forever as replay. 20-30% of revenue from replay viewers. Can run as automated webinar. Generates revenue for years.
- Compound effect over time: Week 1: 200 attendees, 10 clients. Week 4: 300 attendees (pixel optimized), 18 clients + replay sales. Month 3: 400 attendees + email list + lookalikes = $200K/month.
- Pixel optimization creates compounding returns. Facebook learns who converts best. CPL decreases, lead quality increases. After 50+ conversions, algorithm becomes incredibly efficient.
- Build email list while generating revenue. 5,000+ emails in 2-3 months possible. Email list becomes compounding asset.
- WhatsApp groups = reusable audience. Re-run webinars to same groups multiple times. Kala & Eskil: $250K in 2 weeks from 3 WhatsApp groups. Each group can be monetized 3-5 times.

LEAD QUALITY:
- Self-selecting high-intent leads. Low-intent people don't show up (won't sit 90min). Natural qualification filter built-in. Only serious buyers book calls.
- Better data on lead quality. See exactly when each person joined/left. Prioritize sales calls by watch time.
- Higher show rates on booked calls: 75% vs 50% on cold leads. More committed and invested after 90 minutes.
- Qualified leads pre-frame themselves. They understand the problem deeply. Know what the solution looks like. Self-identify as ideal customer.

MARKETING & POSITIONING:
- Create urgency without being sleazy. Live event = real deadline. Limited spots = genuine scarcity. Not fake countdown timers.
- Perfect vehicle for bonuses. Stack massive value. Limited-time bonuses create FOMO. Bonuses offset price objections.
- Social proof in real-time. People see others signing up. Group buying psychology kicks in. Reduces risk perception.
- Content repurposing goldmine. One 90-min webinar = 50+ pieces of content (YouTube, email series, social clips, course modules).

COMPETITIVE ADVANTAGE:
- Most competitors won't do webinars (too hard). Technical setup and live delivery are barriers to entry. Protects your market position.
- Premium pricing justification. 90 minutes of free expertise delivered. High-ticket offer feels reasonable after receiving that much value.
- Works when other funnels don't. VSLs getting tired? Cold calls not working? Webinars convert where traditional methods saturate.
- First-mover advantage in most niches. Be the only one running webinars. Set the standard. Harder for competitors to copy.

PSYCHOLOGICAL ADVANTAGES:
- Reciprocity principle. Give 90 minutes of free value. People feel obligated to reciprocate. "I got so much, I should buy."
- Commitment & consistency bias. They committed to attending, stayed 90 minutes, more likely to commit to purchase.
- Sunk cost works for you. They invested 90 minutes. Don't want time wasted. Higher action-taking rate.
- Authority bias. You're teaching them (teacher = authority). Reduces resistance to pitch.

OPERATOR/AGENCY BENEFITS:
- Huge differentiator. Most operators only do organic. Webinars + ads = rare combination. Charge $5K-7K setup fees easily.
- Easy to sell to clients: "Put $1 in, get $5 out." Complex enough they can't DIY, easy enough to deliver.
- Sticky client relationships. Webinars require ongoing management. Monthly retainer potential. Hard for client to switch providers.
- Use results as case studies to close new clients. "I did $120K in 3 days for another client."
- Lower refund rates. Buyers are more educated and committed. Watched 90 minutes of value already. Know exactly what they're getting.

KEY SOCIAL PROOF STATS TO USE:
- $120K in 3 days (organic, coach had <5K Instagram followers)
- $130K in 7 days
- $240K in two weeks
- $250K in 2 weeks from 3 WhatsApp groups (Kala & Eskil)
- 60-70% call close rates (vs 20-30% traditional)
- 75% show rates on booked calls
- 5-10x ROAS consistently
- 10-17x ROAS on optimized campaigns
`;


  const errorMsg = document.getElementById('errorMsg');
  errorMsg.classList.remove('visible');

  if (!name || !b1 || !p1) {
    errorMsg.textContent = 'Please fill in at least the prospect name, primary bottleneck, and primary problem.';
    errorMsg.classList.add('visible');
    return;
  }

  document.querySelector('.generate-btn').disabled = true;
  document.getElementById('loading').classList.add('visible');
  document.getElementById('outputSection').classList.remove('visible');

  const bottlenecks = [
    { label: 'Primary', bottleneck: b1, problem: p1 },
    b2 && p2 ? { label: 'Secondary', bottleneck: b2, problem: p2 } : null,
    b3 && p3 ? { label: 'Additional', bottleneck: b3, problem: p3 } : null,
  ].filter(Boolean);

  const bottleneckText = bottlenecks.map(b => `${b.label}: "${b.bottleneck}" → Problem: "${b.problem}"`).join('\n');

  const prompt = `You are an expert outreach copywriter for a conversion system agency. Generate two things:

1. An INITIAL DM
2. A LOOM SCRIPT

Use this exact prospect data:
- Name: ${name}
- Niche: ${niche}
- Offer: ${offer}
- Webinar link: ${webinarLink}

Bottlenecks (already prioritized — use in this exact order):
${bottleneckText}

Webinar system benefits (use the most relevant ones based on the prospect's specific problems):
${WEBINAR_BENEFITS}

INITIAL DM FORMAT:
Hey [name], noticed [primary bottleneck] which is mostly leading to [primary problem], so I created a custom fix for you [webinar link] (p.s. personally recorded the vid explaining how to use this)

Keep it 2-3 sentences max. Conversational. No fluff.

LOOM SCRIPT FORMAT:
Follow this structure exactly:
1. Open: "Hey [name], I went through your page and honestly your offer is solid, the problem isn't what you're selling, it's what's happening before someone decides to buy."
2. "I found [X] specific things that are quietly capping your months and I want to walk you through them."
3. Walk through each bottleneck and problem as SHORT PUNCHY ONE-LINERS — no paragraphs. Format like:
   "• [bottleneck] → [problem in one line]"
   One bullet per bottleneck. Max 1 sentence each. No elaboration.
4. Introduce the webinar system using EXACTLY this paragraph (do not rewrite it):
   "I created this custom webinar registration page for you which is a part of a bigger system, now obviously I do not know much about your offer right now so I can't create the full custom system and give it to you but here's what it looks like"
   Then on a new line add exactly: "(go through the webinar system real quick on Figma)"
5. Then write exactly: "This system is gonna fix all the problems you got and here's how"
   Then show how each problem gets fixed — SHORT BULLET POINTS only. Format like:
   "• [problem] → fixed by [one-line benefit from the webinar system]"
   One line per fix. No paragraphs. No elaboration. Let the points hit.
6. Drop the social proof: "$119k in 7 days, $130k in 7 days, $120k in 3 days — completely organic, coach had under 5K Instagram followers"
7. CTA: red button top right, 20-min call, actionable roadmap promised at minimum
8. Close: "Red button, top right corner — speak soon [name]"

Write naturally, conversationally. No corporate language. Punchy sentences. Make it feel like a real person recorded this.

Output format:
---INITIAL DM---
[dm here]

---LOOM SCRIPT---
[loom script here]`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 2000,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await response.json();
    const text = data.content.map(i => i.text || '').join('\n');

    const dmMatch = text.match(/---INITIAL DM---\n([\s\S]*?)(?=---LOOM SCRIPT---|$)/);
    const loomMatch = text.match(/---LOOM SCRIPT---\n([\s\S]*?)$/);

    document.getElementById('dmOutput').textContent = dmMatch ? dmMatch[1].trim() : text;
    document.getElementById('loomOutput').textContent = loomMatch ? loomMatch[1].trim() : '';
    document.getElementById('outputSection').classList.add('visible');

  } catch (err) {
    errorMsg.textContent = 'Something went wrong generating the scripts. Please try again.';
    errorMsg.classList.add('visible');
  }

  document.getElementById('loading').classList.remove('visible');
  document.querySelector('.generate-btn').disabled = false;
}

function copyText(id, btn) {
  const text = document.getElementById(id).textContent;
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'COPIED ✓';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.textContent = 'COPY';
      btn.classList.remove('copied');
    }, 2000);
  });
}
</script>
</body>
</html>
